# vim: syntax=bash
#
# gitignore.io
function gi() { curl -sLw "\n" https://www.toptal.com/developers/gitignore/api/$@ ;}

# Manual VS Code shell integration
if [[ " $TERM_PROGRAM " == " vscode " ]] ; then
  export VSCODE_INJECTION=1
  precmd () {
    echo -e " \033]633;A\007 "
  }
  preexec () {
    echo -e " \033]633;B\007 "
  }
fi

# User configuration

if [[ -x ${HOME}/.local/bin/poetry ]]; then
  plugins+=("poetry");
fi

if [[ -d ${HOME}/.pyenv ]]; then
  export PYENV_ROOT="${HOME}/.pyenv"
  export PATH="${PYENV_ROOT}/bin:$PATH"
  eval "$(pyenv init --path)"
  plugins+=("pyenv");
fi

if command -v code &>/dev/null; then
  plugins+=("vscode");
fi

if command -v sagecipher &>/dev/null; then
  export PYTHON_KEYRING_BACKEND=sagecipher.keyring.Keyring
  export KEYRING_PROPERTY_SSH_KEY_FINGERPRINT=$(sagecipher list-keys | awk '{print $2}')
fi

## default .config: ~/.config/nvim
## multiple .configs: ~/.config/nvim-_

alias dnvim='NVIM_APPNAME="nvim-dev" nvim'
